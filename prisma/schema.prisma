// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  OWNER
  STUDENT
}

enum SubscriptionTier {
  FREE
  BASIC
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum BillingStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum FeedbackCategory {
  FOOD_QUALITY
  SERVICE
  CLEANLINESS
  BILLING
  OTHER
}

enum StudentPlanStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  tenantId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant?       @relation("TenantStudents", fields: [tenantId], references: [id])
  ownedTenant   Tenant?       @relation("TenantOwner")
  studentPlans  StudentPlan[]
  attendance    Attendance[]
  skipMeals     SkipMeal[]
  feedbacks     Feedback[]
  billings      Billing[]
  qrTokens      QRToken[]

  @@index([tenantId])
  @@index([email])
}

model Tenant {
  id               String           @id @default(cuid())
  name             String
  address          String?
  phone            String?
  ownerId          String           @unique
  inviteCode       String           @unique @default(cuid())
  subscriptionTier SubscriptionTier @default(FREE)
  maxStudents      Int              @default(10)
  billingStatus    BillingStatus    @default(ACTIVE)
  suspendedAt      DateTime?
  suspendReason    String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  owner       User          @relation("TenantOwner", fields: [ownerId], references: [id])
  students    User[]        @relation("TenantStudents")
  mealPlans   MealPlan[]
  menus       Menu[]
  qrTokens    QRToken[]
  attendance  Attendance[]
  skipMeals   SkipMeal[]
  feedbacks   Feedback[]
  billings    Billing[]
  transactions Transaction[]

  @@index([ownerId])
  @@index([inviteCode])
}

model MealPlan {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  price       Float
  totalMeals  Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentPlans StudentPlan[]

  @@index([tenantId])
}

model StudentPlan {
  id          String            @id @default(cuid())
  userId      String
  mealPlanId  String
  startDate   DateTime
  endDate     DateTime
  status      StudentPlanStatus @default(ACTIVE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mealPlanId])
}

model Menu {
  id        String   @id @default(cuid())
  tenantId  String
  date      DateTime @db.Date
  dayType   String?  // e.g. "weekday", "weekend", "special"
  meals     Json     // { breakfast: [...], lunch: [...], dinner: [...] }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId])
  @@index([date])
}

model QRToken {
  id          String   @id @default(cuid())
  tenantId    String
  token       String   @unique
  date        DateTime @db.Date
  expiresAt   DateTime
  createdById String
  createdAt   DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  User       @relation(fields: [createdById], references: [id])
  attendance Attendance[]

  @@unique([tenantId, date])
  @@index([token])
  @@index([tenantId])
}

model Attendance {
  id          String   @id @default(cuid())
  userId      String
  tenantId    String
  qrTokenId   String
  date        DateTime @db.Date
  scannedAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  qrToken  QRToken  @relation(fields: [qrTokenId], references: [id])

  @@unique([userId, date])
  @@index([userId])
  @@index([tenantId])
  @@index([date])
}

model SkipMeal {
  id          String   @id @default(cuid())
  userId      String
  tenantId    String
  date        DateTime @db.Date
  requestedAt DateTime @default(now())
  approved    Boolean  @default(true)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([tenantId])
  @@index([date])
}

model Feedback {
  id        String           @id @default(cuid())
  userId    String
  tenantId  String
  category  FeedbackCategory @default(OTHER)
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
}

model Billing {
  id           String   @id @default(cuid())
  userId       String
  tenantId     String
  month        DateTime @db.Date // first day of the month
  mealsTaken   Int      @default(0)
  mealsSkipped Int      @default(0)
  totalMeals   Int      @default(0)
  amount       Float    @default(0)
  isPaid       Boolean  @default(false)
  generatedAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId])
  @@index([tenantId])
  @@index([month])
}

model Transaction {
  id                  String        @id @default(cuid())
  tenantId            String
  razorpayOrderId     String        @unique
  razorpayPaymentId   String?
  razorpaySignature   String?
  amount              Float
  currency            String        @default("INR")
  plan                SubscriptionTier
  status              PaymentStatus @default(PENDING)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([razorpayOrderId])
}
